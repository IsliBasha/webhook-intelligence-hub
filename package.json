{
  "name": "webhook-intelligence-hub",
  "version": "0.1.0",
  "type": "module",
  "description": "Webhook routing with Claude classification, HMAC verification, idempotency, and a Postgres-backed dead-letter queue",
  "scripts": {
    "dev": "tsx src/index.ts",
